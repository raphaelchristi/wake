{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Wake Helm chart values",
  "description": "Partial schema — validates the backup section + top-level shape. Add new sections as adopting Helm's --validate workflow expands.",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "apiKey": { "type": "string" },
        "oauthStateSecret": { "type": "string" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "user": { "type": "string" },
        "database": { "type": "string" },
        "password": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "backup": {
      "type": "object",
      "description": "Pgbackrest backup configuration (Phase 6 Tier 0 gap #3).",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master switch. Default false (opt-in). Set true to render backup CronJobs."
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "schedule": {
          "type": "object",
          "properties": {
            "full": {
              "type": "string",
              "description": "Cron expression for weekly full backups (UTC).",
              "pattern": "^[0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+$"
            },
            "incremental": {
              "type": "string",
              "description": "Cron expression for daily incremental backups (UTC).",
              "pattern": "^[0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+$"
            }
          },
          "required": ["full", "incremental"]
        },
        "retention": {
          "type": "object",
          "properties": {
            "full": {
              "type": "integer",
              "minimum": 1,
              "maximum": 52,
              "description": "Number of weekly full backups to keep."
            },
            "incremental": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "description": "Number of incremental backups to keep."
            }
          },
          "required": ["full", "incremental"]
        },
        "repositoryId": {
          "type": "string",
          "description": "REQUIRED when backup.enabled=true (Phase 6.1 finding #5). Cluster-unique value woven into stanza + repo1-path. Two clusters sharing a bucket MUST pick different values to avoid silent collisions on stanza, WAL archive, and retention expiry. Empty when backup is disabled.",
          "pattern": "^([a-z0-9][a-z0-9-]{0,62})?$"
        },
        "stanza": {
          "type": "string",
          "description": "Pgbackrest stanza name. Empty = derived from repositoryId + release name."
        },
        "processMax": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "description": "Parallelism for compression / upload."
        },
        "archiveCheck": {
          "type": "boolean"
        },
        "s3": {
          "type": "object",
          "properties": {
            "endpoint": { "type": "string" },
            "bucket": { "type": "string" },
            "region": { "type": "string" },
            "uriStyle": { "type": "string", "enum": ["path", "host"] },
            "verifyTls": { "type": "boolean" },
            "secretName": {
              "type": "string",
              "description": "BYO Secret reference. Empty = chart renders inline Secret from accessKeyId/secretAccessKey."
            },
            "accessKeyId": { "type": "string" },
            "secretAccessKey": { "type": "string" }
          }
        },
        "restoreTest": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "hookType": {
              "type": "string",
              "enum": ["test", "post-install", "post-upgrade", "post-install,post-upgrade"]
            },
            "storage": {
              "type": "object",
              "properties": {
                "size": { "type": "string" },
                "storageClass": { "type": "string" }
              }
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object" },
            "limits": { "type": "object" }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      },
      "required": ["enabled"]
    },
    "retention": {
      "type": "object",
      "description": "Retention CronJobs (Phase 7 gap #5): archive + purge for event log TTL.",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master switch. Default false (opt-in). Set true to render retention CronJobs."
        },
        "eventsTtlDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 36500,
          "description": "Local event log TTL (days)."
        },
        "sessionsTtlDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 36500,
          "description": "Session row TTL (reserved — informational today)."
        },
        "archive": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": {
              "type": "string",
              "pattern": "^[0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+$"
            },
            "beforeDays": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3650
            },
            "s3Bucket": {
              "type": "string",
              "description": "S3 URL (s3://bucket[/prefix])."
            },
            "awsRegion": { "type": "string" },
            "awsSecretRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            },
            "batchSize": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            "deleteAfterUpload": { "type": "boolean" }
          }
        },
        "purge": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": {
              "type": "string",
              "pattern": "^[0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+ [0-9*,/\\-]+$"
            }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": { "type": "object" },
            "limits": { "type": "object" }
          }
        }
      },
      "required": ["enabled"]
    }
  }
}
