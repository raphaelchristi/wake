# Keep the build context small and reproducible.

# VCS
.git
.gitignore

# Virtualenvs
.venv
venv
env

# Python build/test artefacts
__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
build/
dist/
.eggs/
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov/

# Editor cruft
.idea
.vscode
*.swp
*.swo

# Tests + examples — not needed at runtime
tests/
examples/
docs/
phases/

# Local data
*.db
*.sqlite
*.sqlite3
.wake/
data/

# CI metadata
.github/
